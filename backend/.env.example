# SQL Server connection string for Prisma
# Format: sqlserver://HOST:PORT;database=DB_NAME;user=USER;password=PASSWORD;encrypt=true
DATABASE_URL="sqlserver://localhost:1433;database=ExpenseTracker;user=sa;password=YourPassword123!;encrypt=false;trustServerCertificate=true"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d

# Server
PORT=3000
NODE_ENV=development

# Anthropic AI (for insights)
ANTHROPIC_API_KEY=your-anthropic-api-key

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# CORS
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081
